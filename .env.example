# Slack tokens (required for Slack integration)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Gateway server
GATEWAY_PORT=18789
GATEWAY_HOST=0.0.0.0
AUTH_TOKEN=your-secret-auth-token

# Agent CLI (claude or codex)
AGENT_CLI=claude
AGENT_WORKSPACE=/path/to/your/workspace

# Optional: override model
# AGENT_MODEL=claude-sonnet-4-20250514

# Orchestration library (must be pip installed)
# pip install jleechanorg-orchestration
