FROM node:22-slim

RUN apt-get update && apt-get install -y \
    tmux \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash sandbox
USER sandbox

WORKDIR /home/sandbox/app
COPY --chown=sandbox:sandbox package.json pnpm-lock.yaml ./
RUN corepack enable && pnpm install --frozen-lockfile --prod

COPY --chown=sandbox:sandbox . .

# Restricted: no network by default (set via docker run --network=none)
# Read-only filesystem (set via docker run --read-only)
# Resource limits (set via docker run --cpus --memory)

EXPOSE 19876

CMD ["node", "dist/entry.js"]
