{
  "name": "agent-gateway",
  "version": "0.1.0",
  "description": "Multi-channel AI gateway with CLI agent orchestration",
  "keywords": [
    "ai",
    "orchestration",
    "slack",
    "gateway",
    "agents"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-gateway": "dist/entry.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx src/entry.ts gateway",
    "start": "node dist/entry.js gateway",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:api": "vitest run tests/api",
    "test:browser": "vitest run tests/browser",
    "lint": "echo 'no linter configured yet'"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.23.0"
}